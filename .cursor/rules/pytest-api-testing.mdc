### 10. Allure报告集成

```python
# ✅ GOOD: 添加Allure步骤和附件
import allure

def test_user_registration(api_client):
    with allure.step("准备注册数据"):
        payload = {"username": "newuser", "email": "new@test.com"}
        allure.attach(json.dumps(payload, indent=2), "请求数据", allure.attachment_type.JSON)

    with allure.step("发送注册请求"):
        response = api_client.post("/register", json=payload)
        allure.attach(str(response.status_code), "状态码", allure.attachment_type.TEXT)

    with allure.step("验证响应"):
        data = response.json()
        assert data["success"] is True
        allure.attach(data["user_id"], "用户ID", allure.attachment_type.TEXT)
```

